{
  "installCommand": "pnpm run vercel:install",
  "buildCommand": "pnpm run vercel:build",
  "crons": [
    {
      "path": "/api/cron/ingest/backfill-artists",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ingest/backfill-artworks",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/ingest/regions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ingest/venues",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/ingest/discovery",
      "schedule": "0 6 * * *"
    }
  ]
}
