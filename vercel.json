{
  "installCommand": "pnpm run vercel:install",
  "buildCommand": "pnpm run vercel:build",
  "crons": [
    {
      "path": "/api/cron/ingest/backfill-artists",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/ingest/backfill-artworks",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/ingest/regions",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/ingest/venues",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/ingest/discovery",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/digests/weekly",
      "schedule": "20 2 * * 0"
    },
    {
      "path": "/api/cron/editorial-notifications",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/geocode-venues",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/cron/health",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/outbox/send",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/retention/engagement",
      "schedule": "35 2 * * *"
    },
    {
      "path": "/api/cron/sync-google-events",
      "schedule": "0 * * * *"
    }
  ]
}
