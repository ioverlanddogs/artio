{
  "name": "artpulse-demo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pretypecheck": "prisma generate",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "pnpm test:node:ci",
    "smoke": "node --test test/smoke.test.js && node -e \"fetch('http://localhost:3000/api/health').then(r=>r.json()).then(console.log).catch(()=>process.exit(0))\"",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "postinstall": "prisma generate",
    "prisma:check-migration-order": "node scripts/check-migration-order.mjs",
    "check-env": "node scripts/check-env.mjs",
    "perf:smoke": "node scripts/perf-smoke.mjs",
    "vercel:build": "prisma generate && node scripts/check-env.mjs --mode=vercel-build && next build && node scripts/cleanup-next-cache.mjs && node scripts/report-build-sizes.mjs",
    "vercel:install": "pnpm install --frozen-lockfile",
    "prisma:safe-deploy": "tsx scripts/prisma-safe-deploy.ts",
    "test:node": "node scripts/run-node-tests.mjs",
    "test:node:ci": "node scripts/run-node-tests.mjs --test-reporter=spec",
    "backfill:venue-timezones": "node scripts/backfill-venue-timezones.mjs",
    "email:dev": "email dev --dir lib/email/templates",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report playwright-report"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@prisma/client": "^6.3.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.39.0",
    "@vercel/blob": "^0.27.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.475.0",
    "mapbox-gl": "^3.18.1",
    "next": "15.5.12",
    "next-auth": "^4.24.13",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwind-merge": "^2.6.0",
    "tz-lookup": "^6.1.25",
    "zod": "^4.3.6",
    "leaflet": "^1.9.4",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "resend": "^4.6.0",
    "@react-email/components": "^0.5.7",
    "react-email": "^4.0.17",
    "stripe": "^17.7.0",
    "qrcode": "^1.5.4",
    "googleapis": "^144.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "eslint": "^9.19.0",
    "eslint-config-next": "15.5.12",
    "postcss": "^8.5.1",
    "prisma": "^6.3.1",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.7.3",
    "@types/leaflet": "^1.9.20",
    "@types/qrcode": "^1.5.5",
    "@playwright/test": "^1.55.0"
  }
}
