  REJECTED
  DUPLICATE
}

enum GalleryCrawlStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum GalleryExtractionStatus {
  PENDING
  SUCCEEDED
  FAILED
}

enum DiscoveryEntityType {
  VENUE
  ARTIST
  EVENT
}

enum DiscoveryGoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum DiscoveryJobStatus {
  PENDING
