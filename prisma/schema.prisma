  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  INVITE_CREATED
  DIGEST_READY
  ARTWORK_VIEW_MILESTONE
  SAVED_SEARCH_MATCH
  VENUE_CLAIM_VERIFY
  VENUE_CLAIM_APPROVED
  VENUE_CLAIM_REJECTED
  VENUE_CLAIM_INVITE
  RSVP_CONFIRMED
  RSVP_CANCELLED
  EVENT_CHANGE_NOTIFY
  EVENT_REMINDER_24H
  NEW_USER_WELCOME
  BROADCAST
  ARTWORK_INQUIRY_BUYER
  ARTWORK_INQUIRY_ARTIST
}

enum CampaignType {
  BROADCAST
  VENUE_CLAIM_INVITE
}

enum ArtistVenueAssociationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CvEntryType {
  EXHIBITION_SOLO
  EXHIBITION_GROUP
  RESIDENCY
  AWARD
  EDUCATION
  PUBLICATION
  OTHER
}

enum SavedSearchType {
  NEARBY
  EVENTS_FILTER
  ARTWORK
}

enum DigestFrequency {
  WEEKLY
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED_UNSUBSCRIBED
}

enum CampaignAudience {
  ALL_USERS
  VENUE_OWNERS
  ARTISTS
  NEW_USERS_7D
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum NotificationInboxStatus {
