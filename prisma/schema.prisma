generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  EDITOR
  ADMIN
}

enum VenueMembershipRole {
  OWNER
  EDITOR
}

enum VenueInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum VenueClaimStatus {
  UNCLAIMED
  PENDING
  CLAIMED
}

enum VenueClaimRequestStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  EXPIRED
  REVOKED
}

enum SubmissionType {
  EVENT
  VENUE
  ARTIST
  ARTWORK
}

enum SubmissionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ContentStatus {
  DRAFT
  ONBOARDING
  IN_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  PUBLISHED
  ARCHIVED
}

enum EnrichmentEntityType {
  ARTIST
  ARTWORK
  VENUE
  EVENT
}

enum EnrichmentGapFilter {
  ALL
  MISSING_BIO
  MISSING_DESCRIPTION
  MISSING_IMAGE
}

enum EnrichmentStatusFilter {
  ALL
  DRAFT
  ONBOARDING
  IN_REVIEW
  PUBLISHED
}

enum EnrichmentRunStatus {
  PENDING
  RUNNING
  STAGED
  COMPLETED
  FAILED
}

enum EnrichmentRunItemStatus {
  PENDING
  STAGED
  SKIPPED
  SUCCESS
  FAILED
}

enum SubmissionKind {
  PUBLISH
  REVISION
}

