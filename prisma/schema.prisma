generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  EDITOR
  ADMIN
}

enum VenueMembershipRole {
  OWNER
  EDITOR
}

enum VenueInviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum VenueClaimStatus {
  UNCLAIMED
  PENDING
  CLAIMED
}

enum VenueClaimRequestStatus {
  PENDING_VERIFICATION
  VERIFIED
  REJECTED
  EXPIRED
  REVOKED
}

enum SubmissionType {
  EVENT
  VENUE
  ARTIST
  ARTWORK
}

enum SubmissionStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
}

enum ContentStatus {
  DRAFT
  ONBOARDING
  IN_REVIEW
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  PUBLISHED
  ARCHIVED
}

enum SubmissionKind {
  PUBLISH
  REVISION
}

enum NotificationType {
  SUBMISSION_SUBMITTED
  SUBMISSION_APPROVED
  SUBMISSION_REJECTED
  INVITE_CREATED
  DIGEST_READY
  ARTWORK_VIEW_MILESTONE
  SAVED_SEARCH_MATCH
  VENUE_CLAIM_VERIFY
  VENUE_CLAIM_APPROVED
  VENUE_CLAIM_REJECTED
  VENUE_CLAIM_INVITE
  RSVP_CONFIRMED
  RSVP_CANCELLED
  EVENT_CHANGE_NOTIFY
  EVENT_REMINDER_24H
  NEW_USER_WELCOME
  BROADCAST
  ARTWORK_INQUIRY_BUYER
  ARTWORK_INQUIRY_ARTIST
}

enum CampaignType {
  BROADCAST
  VENUE_CLAIM_INVITE
}

enum ArtistVenueAssociationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CvEntryType {
  EXHIBITION_SOLO
  EXHIBITION_GROUP
  RESIDENCY
  AWARD
  EDUCATION
  PUBLICATION
  OTHER
}

enum SavedSearchType {
  NEARBY
  EVENTS_FILTER
  ARTWORK
}

enum DigestFrequency {
  WEEKLY
}

enum NotificationStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  SKIPPED_UNSUBSCRIBED
}

enum CampaignAudience {
  ALL_USERS
  VENUE_OWNERS
  ARTISTS
  NEW_USERS_7D
  CUSTOM
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

enum NotificationInboxStatus {
  UNREAD
  READ
}

enum EventType {
  EXHIBITION
  FAIR
  OPENING
  WORKSHOP
  TALK
  SCREENING
  RESIDENCY
  OTHER
}

enum TicketingMode {
  EXTERNAL
  RSVP
  PAID
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
  WAITLISTED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum IngestStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum IngestExtractedEventStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
}

enum IngestArtistStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
}

enum IngestArtworkStatus {
  PENDING
  APPROVED
  REJECTED
  DUPLICATE
}

enum DiscoveryEntityType {
  VENUE
  ARTIST
  EVENT
}

enum DiscoveryJobStatus {
  PENDING
  RUNNING
  DONE
  FAILED
}

enum DiscoveryCandidateStatus {
  PENDING
  QUEUED
  DONE
  SKIPPED
}

enum IngestRegionStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  PAUSED
}

enum FavoriteTargetType {
  EVENT
  VENUE
  ARTIST
  ARTWORK
}

enum FollowTargetType {
  ARTIST
  VENUE
}

enum EngagementSurface {
  DIGEST
  NEARBY
  SEARCH
  FOLLOWING
}

enum EngagementAction {
  VIEW
  CLICK
  FOLLOW
  SAVE_SEARCH
  HIDE
}

enum AssetKind {
  IMAGE
}

enum BetaAccessRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum StripeAccountStatus {
  PENDING
  ACTIVE
  RESTRICTED
  DEAUTHORIZED
}

enum ArtworkOrderStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REFUNDED
}

enum ArtworkOfferStatus {
  PENDING
  ACCEPTED
  COUNTERED
  DECLINED
  EXPIRED
}

enum AnalyticsEntityType {
  ARTWORK
  ARTIST
  VENUE
  EVENT
}

enum EditorialNotificationKind {
  COLLECTION_GOES_LIVE_SOON
  COLLECTION_EXPIRES_SOON
  COLLECTION_QA_ISSUES
  RANK_COLLISION_ALERT
}

enum VenueIngestFrequency {
  DAILY
  WEEKLY
  MONTHLY
  MANUAL
}

model User {
  id                   String                @id @default(uuid()) @db.Uuid
  email                String                @unique
  name                 String?
  imageUrl             String?
  role                 Role                  @default(USER)
  isTrustedPublisher   Boolean               @default(false)
  trustedPublisherSince DateTime?
  trustedPublisherById String?               @db.Uuid
  trustedPublisherBy   User?                  @relation("TrustedPublisherGrantedBy", fields: [trustedPublisherById], references: [id])
  grantedTrustedPublisherUsers User[]         @relation("TrustedPublisherGrantedBy")
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  favorites            Favorite[]
  attendances          Attendance[]
  venueMemberships     VenueMembership[]
  submissions          Submission[]          @relation("SubmissionSubmitter")
  decidedSubmissions   Submission[]          @relation("SubmissionDecider")
  sentVenueInvites     VenueInvite[]         @relation("VenueInviteInvitedBy")
  ownedAssets          Asset[]
  follows              Follow[]
  perfSnapshotsCreated PerfSnapshot[]
  notifications        Notification[]
  savedSearches        SavedSearch[]
  digestRuns           DigestRun[]
  ingestRegionsTriggered IngestRegion[]
  engagementEvents     EngagementEvent[]
  onboardingState      OnboardingState?
  artistProfile        Artist?
  locationLabel        String?
  locationLat          Float?
  locationLng          Float?
  locationRadiusKm     Int                   @default(25)
  digestEnabled        Boolean               @default(true)
  digestEventsOnly     Boolean               @default(false)
  digestRadiusKm       Int?
  digestMaxEvents      Int                   @default(10)
  betaAccessRequests   BetaAccessRequest[]
  betaFeedbackEntries  BetaFeedback[]
  adminInvitesCreated  AdminInvite[]         @relation("AdminInviteCreatedBy")
  importMappingPresets ImportMappingPreset[]
  pageViewEvents       PageViewEvent[]
  venueGenerationRunsTriggered VenueGenerationRun[]
  venueClaimRequests   VenueClaimRequest[]
  venueClaimInvitesCreated VenueClaimInvite[]
  selectedHomepageImageCandidates VenueHomepageImageCandidate[]
  emailCampaignsCreated EmailCampaign[]
  registrations       Registration[]
  artworkOrders      ArtworkOrder[]

  @@index([locationLat, locationLng])
}

model ImportMappingPreset {
  id          String   @id @default(uuid()) @db.Uuid
  entityType  String
  name        String
  mappingJson Json
  createdById String   @db.Uuid
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@unique([createdById, entityType, name])
  @@index([createdById, entityType, updatedAt])
}

model BetaAccessRequest {
  id        String                  @id @default(uuid()) @db.Uuid
  email     String                  @unique
  note      String?
  status    BetaAccessRequestStatus @default(PENDING)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  userId    String?                 @db.Uuid
  user      User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model BetaFeedback {
  id        String   @id @default(uuid()) @db.Uuid
  email     String?
  pagePath  String?
  message   String
  meta      Json?
  createdAt DateTime @default(now())
  userId    String?  @db.Uuid
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
}

model EngagementEvent {
  id         String            @id @default(uuid()) @db.Uuid
  userId     String?           @db.Uuid
  sessionId  String?
  surface    EngagementSurface
  action     EngagementAction
  targetType String
  targetId   String
  metaJson   Json?
  createdAt  DateTime          @default(now())
  user       User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([surface, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([userId, surface, createdAt])
}

model OnboardingState {
  id                     String    @id @default(uuid()) @db.Uuid
  userId                 String    @unique @db.Uuid
  completedAt            DateTime?
  hasFollowedSomething   Boolean   @default(false)
  hasVisitedFollowing    Boolean   @default(false)
  hasAcceptedInvite      Boolean   @default(false)
  hasCreatedVenue        Boolean   @default(false)
  hasSubmittedEvent      Boolean   @default(false)
  hasViewedNotifications Boolean   @default(false)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PerfSnapshot {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  createdAt       DateTime @default(now())
  createdByUserId String?  @db.Uuid
  paramsJson      Json
  explainText     String
  durationMs      Int?
  createdBy       User?    @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([name, createdAt])
  @@index([createdByUserId])
}


model CronJob {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  endpoint    String
  schedule    String
  enabled     Boolean  @default(true)
  nextFireAt  DateTime?
  lastFiredAt DateTime?
  lastStatus  String?
  lastMessage String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([nextFireAt])
  @@index([enabled, nextFireAt])
}

model Venue {
  id                 String                   @id @default(uuid()) @db.Uuid
  name               String
  slug               String                   @unique
  description        String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  region             String?
  country            String?
  postcode           String?
  lat                Float?
  lng                Float?
  timezone           String?
  websiteUrl         String?
  canonicalUrl       String?
  eventsPageUrl      String?                   @map("eventsPageUrl")
  ingestFrequency    VenueIngestFrequency      @default(WEEKLY)
  instagramUrl       String?
  facebookUrl        String?
  contactEmail       String?
  contactPhone       String?
  openingHours       Json?
  lastEnrichedAt     DateTime?                @db.Timestamptz
  enrichmentSource   String?
  wikipediaPageId    String?
  wikipediaUrl       String?
  featuredImageUrl   String?
  featuredAssetId    String?                  @db.Uuid
  /// @deprecated Use `status` (ContentStatus) as canonical publish lifecycle state.
  isPublished        Boolean                  @default(false)
  status             ContentStatus            @default(DRAFT)
  submittedAt        DateTime?
  reviewedAt         DateTime?
  reviewNotes        String?
  aiGenerated        Boolean                  @default(false)
  aiGeneratedAt      DateTime?
  claimStatus        VenueClaimStatus         @default(UNCLAIMED)
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  deletedAt          DateTime?
  deletedByAdminId   String?                  @db.Uuid
  deletedReason      String?
  events             Event[]
  eventSeries        EventSeries[]
  images             VenueImage[]
  memberships        VenueMembership[]
  invites            VenueInvite[]
  submissions        Submission[]             @relation("SubmissionVenue")
  targetSubmissions  Submission[]             @relation("SubmissionTargetVenue")
  featuredAsset      Asset?                   @relation("VenueFeaturedAsset", fields: [featuredAssetId], references: [id], onDelete: SetNull)
  artistAssociations ArtistVenueAssociation[]
  artworkVenues      ArtworkVenue[]
  ingestRuns         IngestRun[]
  ingestExtractedEvents IngestExtractedEvent[]
  claimRequests      VenueClaimRequest[]
  claimInvites       VenueClaimInvite[]
  generationRunItems VenueGenerationRunItem[]
  homepageImageCandidates VenueHomepageImageCandidate[]
  enrichmentLogs     VenueEnrichmentLog[]
  stripeAccount      StripeAccount?

  @@index([isPublished])
  @@index([status])
  @@index([featuredAssetId])
  @@index([deletedAt])
  @@index([timezone])
  @@index([canonicalUrl])
}

model EventSeries {
  id          String    @id @default(uuid()) @db.Uuid
  title       String
  slug        String    @unique
  description String?
  venueId     String?   @db.Uuid
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  venue       Venue?    @relation(fields: [venueId], references: [id])
  events      Event[]

  @@index([venueId])
}

model VenueGenerationRun {
  id                      String                   @id @default(uuid()) @db.Uuid
  country                 String
  region                  String
  status                  String                   @default("SUCCEEDED")
  totalReturned           Int
  totalCreated            Int
  totalSkipped            Int
  totalFailed             Int                      @default(0)
  geocodeAttempted        Int                      @default(0)
  geocodeSucceeded        Int                      @default(0)
  geocodeFailed           Int                      @default(0)
  geocodeFailureBreakdown Json?
  autoPublishedCount      Int                      @default(0)
  triggeredById           String                   @db.Uuid
  createdAt               DateTime                 @default(now())
  triggeredBy             User                     @relation(fields: [triggeredById], references: [id], onDelete: Restrict)
  items                   VenueGenerationRunItem[]

  @@index([createdAt])
}

model VenueGenerationRunItem {
  id               String             @id @default(uuid()) @db.Uuid
  runId             String             @db.Uuid
  name              String
  city              String?
  postcode          String?
  country           String
  status            String
  reason            String?
  venueId           String?            @db.Uuid
  instagramUrl      String?
  facebookUrl       String?
  contactEmail      String?
  websiteUrl        String?
  openingHours      String?
  contactPhone      String?
  addressLine1      String?
  addressLine2      String?
  region            String?
  featuredImageUrl  String?
  socialWarning     String?
  geocodeStatus     String             @default("not_attempted")
  geocodeErrorCode  String?
  timezoneWarning   String?
  homepageImageStatus String           @default("skipped")
  homepageImageCandidateCount Int      @default(0)
  eventsPageStatus  String             @default("not_attempted")
  createdAt         DateTime           @default(now())
  run               VenueGenerationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  venue             Venue?             @relation(fields: [venueId], references: [id], onDelete: SetNull)
  homepageImageCandidates VenueHomepageImageCandidate[]

  @@index([runId, status])
  @@index([runId, geocodeStatus])
  @@index([venueId])
  @@index([createdAt])
}

model VenueHomepageImageCandidate {
  id           String    @id @default(uuid()) @db.Uuid
  venueId      String    @db.Uuid
  runItemId    String?   @db.Uuid
  url          String
  source       String
  sortOrder    Int
  status       String    @default("pending")
  selectedAt   DateTime?
  selectedById String?   @db.Uuid
  venueImageId String?   @db.Uuid
  createdAt    DateTime  @default(now()) @db.Timestamptz

  venue      Venue                  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  runItem    VenueGenerationRunItem? @relation(fields: [runItemId], references: [id], onDelete: Cascade)
  selectedBy User?                  @relation(fields: [selectedById], references: [id], onDelete: SetNull)
  venueImage VenueImage?            @relation(fields: [venueImageId], references: [id], onDelete: SetNull)

  @@index([venueId, status])
  @@index([runItemId])
}

model VenueClaimRequest {
  id          String                  @id @default(uuid()) @db.Uuid
  venueId     String                  @db.Uuid
  userId      String                  @db.Uuid
  roleAtVenue String
  message     String?
  rejectionReason String?
  tokenHash   String?                 @unique
  expiresAt   DateTime?
  status      VenueClaimRequestStatus @default(PENDING_VERIFICATION)
  createdAt   DateTime                @default(now())
  verifiedAt  DateTime?
  venue       Venue                   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  invite      VenueClaimInvite?

  @@index([venueId])
  @@index([userId])
}

model VenueClaimInvite {
  id              String            @id @default(uuid()) @db.Uuid
  venueId         String            @db.Uuid
  email           String
  token           String            @unique
  personalMessage String?
  sentAt          DateTime?
  expiresAt       DateTime
  claimedAt       DateTime?
  claimId         String?           @unique @db.Uuid
  createdByUserId String            @db.Uuid
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  venue           Venue             @relation(fields: [venueId], references: [id], onDelete: Cascade)
  claim           VenueClaimRequest? @relation(fields: [claimId], references: [id], onDelete: SetNull)
  createdBy       User              @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([venueId, createdAt])
  @@index([email, createdAt])
}

model Artist {
  id                String                   @id @default(uuid()) @db.Uuid
  userId            String?                  @unique @db.Uuid
  name              String
  slug              String                   @unique
  bio               String?
  websiteUrl        String?
  canonicalUrl      String?
  instagramUrl      String?
  twitterUrl        String?
  linkedinUrl       String?
  tiktokUrl         String?
  youtubeUrl        String?
  mediums           String[]                 @default([])
  avatarImageUrl    String?
  featuredImageUrl  String?
  featuredAssetId   String?                  @db.Uuid
  /// @deprecated Use `status` (ContentStatus) as canonical publish lifecycle state.
  isPublished       Boolean                  @default(false)
  isAiDiscovered    Boolean                  @default(false)
  extractionProvider String?
  status            ContentStatus            @default(DRAFT)
  submittedAt       DateTime?
  reviewedAt        DateTime?
  reviewNotes       String?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  deletedAt         DateTime?
  deletedByAdminId  String?                  @db.Uuid
  deletedReason     String?
  user              User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  images            ArtistImage[]
  eventArtists      EventArtist[]
  targetSubmissions Submission[]             @relation("SubmissionTargetArtist")
  featuredAsset     Asset?                   @relation("ArtistFeaturedAsset", fields: [featuredAssetId], references: [id], onDelete: SetNull)
  venueAssociations ArtistVenueAssociation[]
  eventAssociations ArtistEventAssociation[]
  cvEntries         ArtistCvEntry[]
  artworks          Artwork[]
  featuredArtworks  ArtistFeaturedArtwork[]
  ingestCandidates  IngestExtractedArtist[]  @relation("IngestExtractedArtistCreated")
  stripeAccount     ArtistStripeAccount?

  @@index([isPublished])
  @@index([featuredAssetId])
  @@index([deletedAt])
  @@index([canonicalUrl])
}

model ArtistCvEntry {
  id           String      @id @default(uuid()) @db.Uuid
  artistId     String      @db.Uuid
  entryType    CvEntryType
  title        String
  organisation String?
  location     String?
  year         Int
  endYear      Int?
  description  String?
  url          String?
  sortOrder    Int         @default(0)
  createdAt    DateTime    @default(now()) @db.Timestamptz
  updatedAt    DateTime    @updatedAt @db.Timestamptz

  artist       Artist      @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId, year(sort: Desc)])
  @@index([artistId, entryType])
}

model ArtistVenueAssociation {
  id                String                       @id @default(uuid()) @db.Uuid
  artistId          String                       @db.Uuid
  venueId           String                       @db.Uuid
  role              String?
  status            ArtistVenueAssociationStatus @default(PENDING)
  message           String?
  createdAt         DateTime                     @default(now())
  updatedAt         DateTime                     @updatedAt
  requestedByUserId String?                      @db.Uuid
  reviewedByUserId  String?                      @db.Uuid
  reviewedAt        DateTime?
  artist            Artist                       @relation(fields: [artistId], references: [id], onDelete: Cascade)
  venue             Venue                        @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([artistId, venueId])
  @@index([venueId, status, createdAt])
  @@index([artistId, status, createdAt])
}

model ArtistEventAssociation {
  id                String    @id @default(uuid()) @db.Uuid
  artistId          String    @db.Uuid
  eventId           String    @db.Uuid
  status            String    @default("PENDING")
  role              String?
  message           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  requestedByUserId String?   @db.Uuid
  artist            Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  event             Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([artistId, eventId])
  @@index([artistId, status, createdAt])
  @@index([eventId, status, createdAt])
}

model Event {
  id            String         @id @default(uuid()) @db.Uuid
  title         String
  slug          String         @unique
  description   String?
  startAt       DateTime
  endAt         DateTime?
  timezone      String
  eventType     EventType?
  ticketUrl     String?
  ticketingMode TicketingMode?  @default(EXTERNAL)
  capacity      Int?
  rsvpClosesAt  DateTime?
  priceText     String?
  isFree        Boolean?
  organizerName String?
  venueId       String?        @db.Uuid
  seriesId      String?        @db.Uuid
  featuredAssetId String?      @db.Uuid
  lat           Float?
  lng           Float?
  /// @deprecated Use `status` (ContentStatus) as canonical publish lifecycle state.
  isPublished   Boolean        @default(false)
  status        ContentStatus  @default(DRAFT)
  submittedAt   DateTime?
  reviewedAt    DateTime?
  reviewNotes   String?
  publishedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?
  deletedByAdminId String?     @db.Uuid
  deletedReason String?
  isAiExtracted  Boolean        @default(false)
  ingestSourceRunId String?     @db.Uuid
  venue         Venue?         @relation(fields: [venueId], references: [id])
  series        EventSeries?   @relation(fields: [seriesId], references: [id])
  ingestSourceRun IngestRun?    @relation("EventIngestSourceRun", fields: [ingestSourceRunId], references: [id], onDelete: SetNull)
  featuredAsset Asset?         @relation("EventFeaturedAsset", fields: [featuredAssetId], references: [id], onDelete: SetNull)
  images        EventImage[]
  eventTags     EventTag[]
  eventArtists  EventArtist[]
  artistAssociations ArtistEventAssociation[]
  submissions   Submission[]
  artworkEvents ArtworkEvent[]
  attendances   Attendance[]
  ticketTiers   TicketTier[]
  registrations Registration[]
  promoCodes    PromoCode[]
  ingestExtractedCandidate IngestExtractedEvent? @relation("IngestExtractedEventCreatedEvent")
  artistDiscoveryLinks IngestExtractedArtistEvent[]
  extractedArtworks  IngestExtractedArtwork[] @relation("IngestExtractedArtworkSourceEvent")

  @@index([startAt])
  @@index([isPublished])
  @@index([status])
  @@index([venueId])
  @@index([featuredAssetId])
  @@index([isPublished, startAt])
  @@index([isPublished, startAt, id])
  @@index([venueId, startAt])
  @@index([seriesId, startAt])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([ingestSourceRunId])
}

model TicketTier {
  id          String   @id @default(uuid()) @db.Uuid
  eventId     String   @db.Uuid
  name        String
  description String?
  priceAmount Int
  currency    String   @default("GBP")
  capacity    Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  registrations Registration[]

  @@index([eventId])
}

model Registration {
  id                    String             @id @default(uuid()) @db.Uuid
  eventId               String             @db.Uuid
  tierId                String?            @db.Uuid
  promoCodeId           String?            @db.Uuid
  userId                String?            @db.Uuid
  guestName             String
  guestEmail            String
  quantity              Int                @default(1)
  status                RegistrationStatus @default(PENDING)
  confirmationCode      String             @unique
  stripePaymentIntentId String?
  amountPaidGbp         Int?

  checkedInAt           DateTime?
  cancelledAt           DateTime?
  refundedAt            DateTime?
