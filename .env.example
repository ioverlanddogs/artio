# Core app environment
# Use your deployed Postgres URL(s) for production and local URLs for dev.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/artpulse?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/artpulse?schema=public"

# NextAuth / Auth.js
# Required in preview/production. Generate with:
#   openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"

# OAuth (required to enable Google sign-in)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional E2E test bypass for middleware. Only honored outside production.
PLAYWRIGHT="false"

# Admin access is a two-layer system; both layers must allow a request.
# Layer 1 (middleware allowlist): ADMIN_EMAILS / ADMIN_EMAIL_DOMAINS gate /admin and /api/admin routes.
# Changes to this allowlist require a redeploy to take effect.
ADMIN_EMAILS="admin@example.com"
ADMIN_EMAIL_DOMAINS="example.org"
# Layer 2 (DB role): handlers require role=ADMIN in the session JWT from sign-in.
# Promoting/demoting DB role takes effect in JWT after the user signs out and signs back in.


# Optional geocoder provider for server-side venue geocoding (`mapbox` by default)
GEOCODER_PROVIDER="mapbox"
GOOGLE_MAPS_API_KEY=""

# Optional client Mapbox token alias. Nearby map uses Leaflet + OpenStreetMap and does not require this.
# Keep only if you still use client-side Mapbox features.
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=""
# Required for cron endpoints (see vercel.json and RUNBOOK.md)
CRON_SECRET="replace-with-random-string"

# Required for /api/ops/metrics bearer auth (see RUNBOOK.md)
OPS_SECRET="replace-with-random-string"

# Analytics page-view hashing salt (optional but recommended for privacy-safe dedupe)
ANALYTICS_SALT="replace-with-random-string"

# Optional rate limit for /api/analytics/view
RATE_LIMIT_ANALYTICS_VIEW_WRITE_PER_MINUTE="120"
RATE_LIMIT_ANALYTICS_VIEW_WRITE_WINDOW_MS="60000"

# Editorial notification cron (optional sinks)
EDITORIAL_NOTIFICATIONS_WEBHOOK_URL=""
EDITORIAL_NOTIFY_TO=""
EDITORIAL_NOTIFICATIONS_EMAIL_ENABLED="false"

# AI ingest extraction (disabled by default)
AI_INGEST_ENABLED="0"
OPENAI_API_KEY=""
AI_INGEST_MAX_CANDIDATES_PER_VENUE_RUN="25"
AI_INGEST_DUPLICATE_SIMILARITY_THRESHOLD="85"
AI_INGEST_DUPLICATE_LOOKBACK_DAYS="30"
AI_INGEST_CONFIDENCE_HIGH_MIN="75"
AI_INGEST_CONFIDENCE_MEDIUM_MIN="45"
AI_INGEST_CRON_MAX_VENUES="10"
AI_INGEST_CRON_MAX_TOTAL_CREATED_CANDIDATES="100"
AI_INGEST_CRON_TIME_BUDGET_MS="120000"
AI_INGEST_CRON_CIRCUIT_BREAKER_WINDOW_HOURS="6"
AI_INGEST_CRON_CIRCUIT_BREAKER_MIN_RUNS="5"
AI_INGEST_CRON_CIRCUIT_BREAKER_FAIL_RATE="0.6"
AI_INGEST_IMAGE_ENABLED="1"
AI_INGEST_IMAGE_MAX_BYTES="5000000"
BLOB_READ_WRITE_TOKEN=""
